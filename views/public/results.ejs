<%- include('head') %>

<div class="wrap">
  <p class="crumb"><a href="/">Home</a> › Availability</p>
  <h2 class="section-title">Available Rooms</h2>
  <p class="section-sub"><%= checkin %> → <%= checkout %></p>
  <div class="rooms" id="room-grid">
    <div class="loading">Loading availability…</div>
  </div>
</div>

<script>
  (function () {
    var qs = '?checkin=<%= checkin %>&checkout=<%= checkout %>';
    fetch('/api/availability' + qs, { headers: { 'Accept': 'application/json' } })
      .then(function (r) { return r.json(); })
      .then(function (data) {
        var grid = document.getElementById('room-grid');
        grid.innerHTML = '';
        data.rooms.forEach(function (room) {
          var avail = room.soldOut ? '<span class="avail sold">Sold out</span>' : '<span class="avail">' + room.available + ' left</span>';
          var ribbon = room.soldOut ? '<span class="ribbon">Sold out</span>' : '';
          var btnCls = room.soldOut ? 'btn btn-muted' : 'btn';
          var card = document.createElement('div');
          card.className = 'room-card' + (room.soldOut ? ' is-sold-out' : '');
          card.innerHTML =
            '<div class="card-img">' + ribbon + '<img src="' + room.photo + '" alt="' + room.name + '"></div>' +
            '<div class="body"><h3>' + room.name + '</h3><p class="blurb">Sleeps ' + room.sleeps + ' · ' + data.nights + ' night(s)</p>' +
            '<div class="rate"><span class="price">$' + room.rackRate + ' <small>/ night</small></span>' + avail + '</div>' +
            '<div style="margin-top:14px"><a class="' + btnCls + '" href="/rooms/' + room.slug + '">View room</a></div></div>';
          grid.appendChild(card);
        });
      })
      .catch(function () { document.getElementById('room-grid').innerHTML = '<div class="loading">Could not load availability.</div>'; });
  })();
</script>

<%- include('foot') %>
